{
  "name": "preevol-new-backend",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "node dist/index",
    "build": "tsc -p .",
    "dev": "tsc-watch --onSuccess \"bun run start\"",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:migrate" : "drizzle-kit migrate"

  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/express": "^5.0.6",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsc-watch": "^7.2.0",
    "tsx": "^4.22.4"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@types/node": "^25.9.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "pg": "^8.21.0"
  }
}
